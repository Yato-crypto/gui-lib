function BackgroundManager.new(ctx)
    local self = setmetatable({}, BackgroundManager)
    self.ui = ctx.ui
    self.cleaner = ctx.cleaner
    self.asset = ctx.asset
    self.theme = ctx.theme
    self.holder = ctx.holder
    self.spec = {}
    self.frames = {}
    self.cache = {}
    self.failed = {}
    self.front = nil
    self.back = nil
    self.dim = nil
    self.playConn = nil
    self.playing = false
    self.playhead = 1
    self.accum = 0
    self.lastResolve = 0
    self:_buildLayer()
    return self
end

function BackgroundManager:_buildLayer()
    self.holder.BackgroundColor3 = self.theme.BACKDROP
    self.holder.BackgroundTransparency = 0
    self.front = new("ImageLabel", {
        Name = "Front",
        BackgroundTransparency = 1,
        Size = UDim2.fromScale(1, 1),
        ImageTransparency = 0,
        ScaleType = Enum.ScaleType.Crop,
        ZIndex = 1,
    }, self.holder)
    self.back = new("ImageLabel", {
        Name = "Back",
        BackgroundTransparency = 1,
        Size = UDim2.fromScale(1, 1),
        ImageTransparency = 1,
        ScaleType = Enum.ScaleType.Crop,
        ZIndex = 1,
    }, self.holder)
    self.dim = new("Frame", {
        Name = "Dim",
        BackgroundColor3 = Color3.new(0, 0, 0),
        BackgroundTransparency = 0.65,
        BorderSizePixel = 0,
        Size = UDim2.fromScale(1, 1),
        ZIndex = 2,
    }, self.holder)
end

function BackgroundManager:_normaliseSpec(spec)
    local source = spec
    if type(source) == "string" then
        source = CombatCyberGuiLib.Backgrounds.Presets[source] or {preset = source}
    end
    source = source or {}
    local cfg = self.ui.compatCfg or {}
    local out = {
        enabled = source.enabled,
        mode = source.mode or "none",
        preset = source.preset,
        manifest = source.manifest,
        folder = source.folder,
        prefix = source.prefix or "frame_",
        extension = source.extension or ".png",
        startIndex = tonumber(source.startIndex) or 1,
        digits = tonumber(source.digits) or 4,
        count = tonumber(source.count) or 0,
        fps = tonumber(source.fps) or 30,
        loop = source.loop ~= false,
        fit = source.fit or "crop",
        dim = tonumber(source.dim) or 0.34,
        fallbackImage = source.fallbackImage,
        residentLimit = tonumber(source.residentLimit) or 48,
        warmupSeconds = tonumber(source.warmupSeconds) or 2,
        streamMaxFps = tonumber(source.streamMaxFps) or 60,
        sheet = source.sheet,
        frameWidth = tonumber(source.frameWidth) or 0,
        frameHeight = tonumber(source.frameHeight) or 0,
        columns = tonumber(source.columns) or 1,
        rows = tonumber(source.rows) or 1,
    }
    if out.enabled == nil then out.enabled = cfg.domainAnimatedBg == true or cfg.sitrepFramesEnabled == true end
    if not source.mode and cfg.sitrepStreamMode then out.mode = cfg.sitrepStreamMode end
    if not source.folder and cfg.sitrepFramesDir then out.folder = cfg.sitrepFramesDir end
    if (not source.count or source.count == 0) and cfg.sitrepFramesCount then out.count = tonumber(cfg.sitrepFramesCount) or out.count end
    if not source.fps and cfg.sitrepFramesFps then out.fps = tonumber(cfg.sitrepFramesFps) or out.fps end
    if not source.residentLimit and cfg.sitrepResidentFrameLimit then out.residentLimit = tonumber(cfg.sitrepResidentFrameLimit) or out.residentLimit end
    if not source.warmupSeconds and cfg.sitrepResidentWarmupSec then out.warmupSeconds = tonumber(cfg.sitrepResidentWarmupSec) or out.warmupSeconds end
    if out.mode == "frames" and (not out.folder or out.folder == "") then out.mode = "none" end
    if reducedMotion() and out.mode == "frames" then
        out.fps = math.min(out.fps, 12)
        out.residentLimit = math.min(out.residentLimit, 24)
    end
    out.fps = clamp(out.fps, 1, 90)
    out.dim = clamp(out.dim, 0, 0.85)
    out.residentLimit = math.max(2, math.floor(out.residentLimit))
    return out
end

function BackgroundManager:_readManifest(path)
    if type(path) ~= "string" then return nil end
    local ok, text = self.asset:ReadText(path)
    if not ok then return nil end
    local decodedOk, data = pcall(function() return HttpService:JSONDecode(text) end)
    if decodedOk and type(data) == "table" then return data end
    return nil
end

function BackgroundManager:_applyFit()
    local fit = tostring(self.spec.fit or "crop")
    local scale = fit == "fit" and Enum.ScaleType.Fit or Enum.ScaleType.Crop
    self.front.ScaleType = scale
    self.back.ScaleType = scale
end

function BackgroundManager:_frameName(index)
    local n = self.spec.startIndex + index - 1
    local num = tostring(n)
    while #num < self.spec.digits do num = "0" .. num end
    return tostring(self.spec.folder) .. "/" .. tostring(self.spec.prefix) .. num .. tostring(self.spec.extension)
end

function BackgroundManager:_buildFrameIndex()
    self.frames = {}
    if self.spec.mode == "frames" then
        local listed = {}
        if self.spec.folder and self.asset.canList then
            local files = self.asset:ListFiles(self.spec.folder)
            for _, path in ipairs(files) do
                local s = tostring(path)
                local lower = s:lower()
                if lower:match("%.png$") or lower:match("%.jpg$") or lower:match("%.jpeg$") or lower:match("%.webp$") then
                    listed[#listed + 1] = s
                end
            end
            table.sort(listed)
        end
        if #listed > 0 then
            self.frames = listed
            self.spec.count = #listed
        else
            local count = math.max(0, tonumber(self.spec.count) or 0)
            for i = 1, count do
                self.frames[i] = self:_frameName(i)
            end
        end
    elseif self.spec.mode == "spriteSheet" then
        self.frames = {}
        local count = math.max(1, tonumber(self.spec.count) or (self.spec.columns * self.spec.rows))
        for i = 1, count do self.frames[i] = i end
    end
end

function BackgroundManager:_resolveFrame(index)
    if self.cache[index] then return self.cache[index] end
    if self.failed[index] then return nil end
    local frame = self.frames[index]
    if not frame then return nil end
    if self.spec.mode == "spriteSheet" then
        local uri = self.asset:ResolveContent(self.spec.sheet)
        self.cache[index] = uri
        return uri
    end
    local uri, err = self.asset:ResolveContent(frame)
    if uri then
        self.cache[index] = uri
        return uri
    end
    self.failed[index] = err or true
    return nil
end

function BackgroundManager:_spriteRect(index, imageLabel)
    if self.spec.mode ~= "spriteSheet" then return end
    local w = self.spec.frameWidth
    local h = self.spec.frameHeight
    if w <= 0 or h <= 0 then return end
    local i = index - 1
    local col = i % math.max(1, self.spec.columns)
    local row = math.floor(i / math.max(1, self.spec.columns))
    imageLabel.ImageRectOffset = Vector2.new(col * w, row * h)
    imageLabel.ImageRectSize = Vector2.new(w, h)
end

function BackgroundManager:_warmup()
    local warm = math.min(#self.frames, self.spec.residentLimit, math.ceil(self.spec.fps * self.spec.warmupSeconds))
    if warm < 1 then warm = math.min(#self.frames, 1) end
    for i = 1, warm do
        self:_resolveFrame(i)
    end
end

function BackgroundManager:_show(index)
    local uri = self:_resolveFrame(index)
    if not uri or uri == "" then return false end
    self.back.Image = uri
    self:_spriteRect(index, self.back)
    self.back.ImageTransparency = 0
    self.front.ImageTransparency = 1
    local old = self.front
    self.front = self.back
    self.back = old
    self.back.ImageTransparency = 1
    return true
end

function BackgroundManager:_lookahead()
    local total = #self.frames
    if total <= 0 then return end
    local budget = math.min(self.spec.residentLimit, total)
    for n = 1, budget do
        local idx = ((self.playhead + n - 2) % total) + 1
        if not self.cache[idx] and not self.failed[idx] then
            self:_resolveFrame(idx)
            return
        end
    end
end

function BackgroundManager:_step(dt)
    if not self.playing or not self.spec.enabled then return end
    local total = #self.frames
    if total <= 0 then return end
    self.accum = self.accum + dt
    local step = 1 / math.max(1, self.spec.fps)
    if self.accum < step then
        local t = now()
        if t - self.lastResolve > (1 / math.max(1, self.spec.streamMaxFps)) then
            self.lastResolve = t
            self:_lookahead()
        end
        return
    end
    self.accum = self.accum - step
    self:_show(self.playhead)
    self.playhead = self.playhead + 1
    if self.playhead > total then
        if self.spec.loop then self.playhead = 1 else self:Stop() end
    end
end

function BackgroundManager:SetPreset(specOrName)
    local spec = specOrName
    if type(specOrName) == "string" then
        spec = CombatCyberGuiLib.Backgrounds.Presets[specOrName] or {preset = specOrName}
    end
    self.spec = self:_normaliseSpec(spec)
    self:Reload()
end

function BackgroundManager:SetEnabled(value)
    self.spec.enabled = value == true
    if self.spec.enabled then self:Play() else self:Stop() end
end

function BackgroundManager:SetFPS(fps)
    self.spec.fps = clamp(fps, 1, 90)
end

function BackgroundManager:SetDim(dim)
    self.spec.dim = clamp(dim, 0, 0.85)
    if self.dim then self.dim.BackgroundTransparency = 1 - self.spec.dim end
end

function BackgroundManager:SetResidentLimit(limit)
    self.spec.residentLimit = math.max(2, math.floor(tonumber(limit) or self.spec.residentLimit or 48))
end

function BackgroundManager:Reload()
    self:Stop()
    if self.spec.mode == "manifest" then
        local data = self:_readManifest(self.spec.manifest or self.spec.folder)
        if data then
            self.spec = self:_normaliseSpec(merge(self.spec, data))
        else
            self.spec.mode = "none"
        end
    end
    self.cache = {}
    self.failed = {}
    self.playhead = 1
    self.accum = 0
    self:_applyFit()
    self:SetDim(self.spec.dim)
    self:_buildFrameIndex()
    if self.spec.mode == "static" then
        local img = self.spec.image or self.spec.fallbackImage
        local uri = img and self.asset:ResolveContent(img) or nil
        if uri then self.front.Image = uri end
        return
    end
    if self.spec.mode == "frames" or self.spec.mode == "spriteSheet" then
        self:_warmup()
        self:_show(1)
        if self.spec.enabled then self:Play() end
        return
    end
    if self.spec.fallbackImage then
        local uri = self.asset:ResolveContent(self.spec.fallbackImage)
        if uri then self.front.Image = uri end
    end
end

function BackgroundManager:Play()
    if self.playing then return end
    self.playing = true
    if self.playConn then self.playConn:Disconnect() end
    self.playConn = RunService.RenderStepped:Connect(function(dt) self:_step(dt) end)
end

function BackgroundManager:Stop()
    self.playing = false
    if self.playConn then
        self.playConn:Disconnect()
        self.playConn = nil
    end
end

function BackgroundManager:Destroy()
    self:Stop()
    self.cache = {}
    self.failed = {}
end

CombatCyberGuiLib.BackgroundManager = BackgroundManager

local Binding = {}

function Binding.tableKey(tbl, key, transformIn, transformOut)
    return {
        get = function()
            local v = tbl[key]
            if transformOut then return transformOut(v) end
            return v
        end,
        set = function(value)
            if transformIn then value = transformIn(value) end
            tbl[key] = value
        end,
    }
end

function Binding.value(initial)
    local box = {value = initial}
    return {
        get = function() return box.value end,
        set = function(value) box.value = value end,
        box = box,
    }
end

function Binding.computed(getter, setter)
    return {get = getter, set = setter}
end

CombatCyberGuiLib.Bind = Binding

