local Cleaner = {}
Cleaner.__index = Cleaner

function Cleaner.new()
    return setmetatable({tasks = {}, actions = {}, renders = {}}, Cleaner)
end

function Cleaner:Give(taskObj)
    if taskObj ~= nil then
        self.tasks[#self.tasks + 1] = taskObj
    end
    return taskObj
end

function Cleaner:Connect(signal, fn)
    local conn = signal:Connect(fn)
    self:Give(conn)
    return conn
end

function Cleaner:BindAction(name, fn, createTouchButton, ...)
    ContextActionService:BindAction(name, fn, createTouchButton or false, ...)
    self.actions[#self.actions + 1] = name
    return name
end

function Cleaner:BindRenderStep(name, priority, fn)
    RunService:BindToRenderStep(name, priority, fn)
    self.renders[#self.renders + 1] = name
    return name
end

function Cleaner:Destroy()
    for i = #self.actions, 1, -1 do
        pcall(function() ContextActionService:UnbindAction(self.actions[i]) end)
    end
    for i = #self.renders, 1, -1 do
        pcall(function() RunService:UnbindFromRenderStep(self.renders[i]) end)
    end
    for i = #self.tasks, 1, -1 do
        local t = self.tasks[i]
        local kind = typeof(t)
        if kind == "RBXScriptConnection" then
            pcall(function() t:Disconnect() end)
        elseif kind == "Instance" then
            pcall(function() t:Destroy() end)
        elseif kind == "function" then
            pcall(t)
        elseif type(t) == "table" and type(t.Destroy) == "function" then
            pcall(function() t:Destroy() end)
        elseif type(t) == "table" and type(t.Disconnect) == "function" then
            pcall(function() t:Disconnect() end)
        end
    end
    self.tasks = {}
    self.actions = {}
    self.renders = {}
end

CombatCyberGuiLib.Cleaner = Cleaner

local function clamp(n, a, b)
    n = tonumber(n) or a
    if n < a then return a end
    if n > b then return b end
    return n
end

local function safeGet(obj, key, fallback)
    local ok, value = pcall(function() return obj[key] end)
    if ok and value ~= nil then return value end
    return fallback
end

local function now()
    if tick then return tick() end
    return os.clock()
end

local function merge(a, b)
    local out = {}
    for k, v in pairs(a or {}) do out[k] = v end
    for k, v in pairs(b or {}) do out[k] = v end
    return out
end

local function props(inst, tbl)
    for k, v in pairs(tbl or {}) do
        pcall(function() inst[k] = v end)
    end
    return inst
end

local function new(className, tbl, parent)
    local inst = Instance.new(className)
    props(inst, tbl)
    if parent then inst.Parent = parent end
    return inst
end

local function asText(value)
    if value == nil then return "" end
    return tostring(value):gsub("\r", " "):gsub("\n", " ")
end

local function scaleTransparency(value)
    local pref = 1
    pcall(function() pref = GuiService.PreferredTransparency end)
    if type(pref) ~= "number" then pref = 1 end
    local opacity = 1 - clamp(value or 0, 0, 1)
    local adjusted = 1 - (opacity * clamp(pref, 0, 1))
    return clamp(adjusted, 0, 1)
end

local function reducedMotion()
    local ok, value = pcall(function() return GuiService.ReducedMotionEnabled end)
    return ok and value == true
end

