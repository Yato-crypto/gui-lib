local AssetAdapter = {}
AssetAdapter.__index = AssetAdapter

function AssetAdapter.new(custom)
    local self = setmetatable(custom or {}, AssetAdapter)
    self.canRead = type(readfile) == "function"
    self.canWrite = type(writefile) == "function"
    self.canList = type(listfiles) == "function"
    self.canLocalAsset = type(getcustomasset) == "function" or type(getsynasset) == "function"
    return self
end

function AssetAdapter:ReadText(path)
    if type(self.readText) == "function" then
        return self.readText(path)
    end
    if type(readfile) == "function" then
        local ok, text = pcall(readfile, path)
        if ok then return true, text end
        return false, text
    end
    return false, "readfile unavailable"
end

function AssetAdapter:Exists(path)
    if type(self.exists) == "function" then
        return self.exists(path)
    end
    if type(isfile) == "function" then
        local ok, value = pcall(isfile, path)
        return ok and value == true
    end
    local ok = self:ReadText(path)
    return ok == true
end

function AssetAdapter:ListFiles(path)
    if type(self.listFiles) == "function" then
        return self.listFiles(path)
    end
    if type(listfiles) == "function" then
        local ok, files = pcall(listfiles, path)
        if ok and type(files) == "table" then return files end
    end
    return {}
end

function AssetAdapter:ResolveContent(pathOrUri)
    if type(self.resolveContent) == "function" then
        return self.resolveContent(pathOrUri)
    end
    if type(pathOrUri) ~= "string" or pathOrUri == "" then
        return nil, "bad content path"
    end
    if pathOrUri:match("^rbxassetid://") or pathOrUri:match("^rbxasset://") or pathOrUri:match("^http") then
        return pathOrUri
    end
    if type(getcustomasset) == "function" then
        local ok, uri = pcall(getcustomasset, pathOrUri)
        if ok and type(uri) == "string" then return uri end
    end
    if type(getsynasset) == "function" then
        local ok, uri = pcall(getsynasset, pathOrUri)
        if ok and type(uri) == "string" then return uri end
    end
    return pathOrUri
end

CombatCyberGuiLib.AssetAdapter = AssetAdapter

