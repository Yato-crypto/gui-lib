local function callGetter(binding)
    if type(binding) == "table" and type(binding.get) == "function" then
        local ok, value = pcall(binding.get)
        if ok then return value end
    end
    return nil
end

local function callSetter(binding, value)
    if type(binding) == "table" and type(binding.set) == "function" then
        pcall(binding.set, value)
    end
end

local function parentGui(gui, player)
    pcall(function()
        if syn and syn.protect_gui then syn.protect_gui(gui) end
    end)
    local parent = nil
    pcall(function() if gethui then parent = gethui() end end)
    if not parent then pcall(function() parent = game:GetService("CoreGui") end) end
    if parent then
        local ok = pcall(function() gui.Parent = parent end)
        if ok then return end
    end
    gui.Parent = (player or LP):WaitForChild("PlayerGui")
end

function Window:_makeText(parent, opt)
