function Window:_makePanel(parent, opt)
    opt = opt or {}
    local panel = new("Frame", {
        BackgroundColor3 = opt.color or self.theme.SURFACE,
        BackgroundTransparency = scaleTransparency(opt.transparency or self.theme.GLASS),
        BorderSizePixel = 0,
        Size = opt.size or UDim2.fromScale(1, 1),
        Position = opt.pos or UDim2.fromOffset(0, 0),
        ClipsDescendants = opt.clip == true,
        ZIndex = opt.z or 20,
    }, parent)
    Style.corner(panel, opt.radius or self.theme.RADIUS)
    Style.stroke(panel, opt.strokeColor or self.theme.BORDER, opt.strokeTransparency or self.theme.STROKE, opt.strokeThickness or 1)
    return panel
end

function Window:_makeButton(parent, text, callback, opt)
    opt = opt or {}
    local btn = new("TextButton", {
        BackgroundColor3 = opt.color or self.theme.CARD2,
        BackgroundTransparency = scaleTransparency(opt.transparency or 0.16),
        BorderSizePixel = 0,
        AutoButtonColor = false,
        Text = text or "Button",
        TextColor3 = opt.textColor or self.theme.TEXT,
        TextSize = opt.textSize or 12,
        Font = opt.font or self.theme.FONT_BOLD,
        Size = opt.size or UDim2.new(1, 0, 0, 32),
        Position = opt.pos or UDim2.fromOffset(0, 0),
        ZIndex = opt.z or 35,
    }, parent)
    Style.corner(btn, opt.radius or 8)
    Style.stroke(btn, opt.strokeColor or self.theme.BORDER, opt.strokeTransparency or 0.55, 1)
    self.cleaner:Connect(btn.MouseEnter, function()
        if self.destroyed then return end
        if not reducedMotion() then
            TweenService:Create(btn, TweenInfo.new(0.10), {BackgroundTransparency = scaleTransparency(0.05)}):Play()
        else
            btn.BackgroundTransparency = scaleTransparency(0.05)
        end
    end)
    self.cleaner:Connect(btn.MouseLeave, function()
        if self.destroyed then return end
        if not reducedMotion() then
            TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundTransparency = scaleTransparency(opt.transparency or 0.16)}):Play()
        else
            btn.BackgroundTransparency = scaleTransparency(opt.transparency or 0.16)
        end
    end)
    self.cleaner:Connect(btn.MouseButton1Click, function()
        if callback then pcall(callback) end
    end)
    return btn
end

