function Window:_bindInput()
    local toggleKey = self.keyConfig.toggleKey or self.config.toggleKey or Enum.KeyCode.RightShift
    local nextKey = self.keyConfig.nextTabKey or Enum.KeyCode.Right
    local prevKey = self.keyConfig.prevTabKey or Enum.KeyCode.Left
    local ignoreProcessed = self.keyConfig.ignoreProcessed == true or self.keyConfig.ignoreProcessedForGui == true
    self.cleaner:Connect(UserInputService.InputBegan, function(input, processed)
        if self.destroyed then return end
        if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
        if processed and not ignoreProcessed then return end
        local box = UserInputService:GetFocusedTextBox()
        if box then return end
        if input.KeyCode == toggleKey then
            self:Toggle()
        elseif self.open and input.KeyCode == nextKey then
            self:NextTab(1)
        elseif self.open and input.KeyCode == prevKey then
            self:NextTab(-1)
        end
    end)
end

function Window:_applyOpenState(skipTween)
    self.root.Visible = self.open
    self.bgGui.Enabled = self.open or (self.config.backgroundAlwaysVisible == true)
    self.shellGui.Enabled = true
    if skipTween or reducedMotion() then
        self.root.BackgroundTransparency = scaleTransparency(0.08)
        return
    end
    if self.open then
        self.root.BackgroundTransparency = 1
        TweenService:Create(self.root, TweenInfo.new(0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {BackgroundTransparency = scaleTransparency(0.08)}):Play()
    end
end

function Window:SetOpen(value)
    self.open = value == true
    self:_applyOpenState(false)
end

function Window:Toggle()
    self:SetOpen(not self.open)
end

function Window:Tab(name, icon, options)
    local tab = setmetatable({ui = self, name = name, icon = icon, options = options or {}, elements = {}, mounted = false, button = nil, root = nil}, Tab)
    self.tabs[name] = tab
    self.tabOrder[#self.tabOrder + 1] = name
    self:_addTabButton(tab)
    if not self.activeTab then self:SelectTab(name) end
    return tab
end

function Window:_addTabButton(tab)
    local btn = self:_makeButton(self.tabStrip, (tab.icon and (tab.icon .. "  ") or "") .. tab.name, function()
        self:SelectTab(tab.name)
    end, {size = UDim2.new(0, tab.options.width or 145, 1, 0), textSize = 12, font = self.theme.FONT_BODY, transparency = 0.24, z = 35})
    tab.button = btn
end

function Window:_mountTab(tab)
    if tab.mounted then return end
    local scroll = new("ScrollingFrame", {
        Name = tab.name .. "Content",
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = UDim2.fromScale(1, 1),
        CanvasSize = UDim2.fromOffset(0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = self.theme.ACCENT,
        Visible = false,
        ZIndex = 25,
    }, self.body)
    Style.padding(scroll, 0, 0, 6, 12)
    Style.list(scroll, Enum.FillDirection.Vertical, 12, Enum.HorizontalAlignment.Left)
    tab.root = scroll
    tab.mounted = true
    for _, spec in ipairs(tab.elements) do
        spec:_mount(scroll)
    end
end

function Window:SelectTab(name)
    local tab = self.tabs[name]
    if not tab then return end
    self:_mountTab(tab)
    for _, tabName in ipairs(self.tabOrder) do
        local t = self.tabs[tabName]
        if t and t.root then t.root.Visible = (tabName == name) end
        if t and t.button then
            local active = tabName == name
            t.button.BackgroundColor3 = active and self.theme.ACCENT2 or self.theme.CARD2
            t.button.TextColor3 = active and self.theme.TEXT or self.theme.TEXT2
            t.button.BackgroundTransparency = active and scaleTransparency(0.02) or scaleTransparency(0.24)
        end
    end
    self.activeTab = name
    self:Refresh()
end

function Window:NextTab(delta)
    if #self.tabOrder == 0 then return end
    local idx = 1
    for i, name in ipairs(self.tabOrder) do
        if name == self.activeTab then
            idx = i
            break
        end
    end
    idx = idx + delta
    if idx < 1 then idx = #self.tabOrder end
    if idx > #self.tabOrder then idx = 1 end
    self:SelectTab(self.tabOrder[idx])
end

function Window:AddRefresher(fn)
    self.refreshers[#self.refreshers + 1] = fn
    return fn
end

function Window:SetSnapshot(snapshot)
    self.snapshot = snapshot or {}
    self:Refresh()
end

function Window:PatchSnapshot(partial)
    for k, v in pairs(partial or {}) do self.snapshot[k] = v end
    self:Refresh()
end

function Window:GetSnapshot()
    return self.snapshot
end

function Window:SetFooter(left, mid, right)
    if left ~= nil then self.footerLeft.Text = asText(left) end
    if mid ~= nil then self.footerMid.Text = asText(mid) end
    if right ~= nil then self.footerRight.Text = asText(right) end
end

function Window:Refresh()
    for _, fn in ipairs(self.refreshers) do
        pcall(fn, self.snapshot)
    end
end

function Window:Notify(title, body, duration)
    local toast = self:_makePanel(self.toastHolder, {size = UDim2.new(1, 0, 0, 74), transparency = 0.08, radius = 10, z = 90, strokeColor = self.theme.ACCENT, strokeTransparency = 0.30})
    self:_makeText(toast, {text = asText(title or "Notice"), size = 13, font = self.theme.FONT_BOLD, pos = UDim2.fromOffset(14, 8), sizeUDim = UDim2.new(1, -28, 0, 20), color = self.theme.TEXT, z = 91})
    self:_makeText(toast, {text = asText(body or ""), size = 11, font = self.theme.FONT_BODY, pos = UDim2.fromOffset(14, 30), sizeUDim = UDim2.new(1, -28, 0, 34), color = self.theme.TEXT2, wrapped = true, z = 91})
    task.delay(tonumber(duration) or 2.4, function()
        if toast and toast.Parent then
            if reducedMotion() then toast:Destroy() return end
            local tw = TweenService:Create(toast, TweenInfo.new(0.18), {BackgroundTransparency = 1})
            tw:Play()
            task.delay(0.20, function() if toast then toast:Destroy() end end)
        end
    end)
    return toast
end

function Window:Destroy()
    if self.destroyed then return end
    self.destroyed = true
    if self.Background then self.Background:Destroy() end
    self.cleaner:Destroy()
end

