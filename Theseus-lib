function SectionSpec:_mountControl(parent, ctrl)
    local ui = self.tab.ui
    if ctrl.kind == "button" then
        ui:_makeButton(parent, ctrl.label, ctrl.callback, {size = UDim2.new(1, 0, 0, 34)})
        return
    end
    if ctrl.kind == "toggle" then
        local btn = ui:_makeButton(parent, ctrl.label, function()
            local value = callGetter(ctrl.binding)
            callSetter(ctrl.binding, not value)
            ui:Refresh()
            if ctrl.callback then pcall(ctrl.callback, not value) end
        end, {size = UDim2.new(1, 0, 0, 34), font = ui.theme.FONT_BOLD})
        ui:AddRefresher(function()
            local value = callGetter(ctrl.binding)
            btn.Text = ctrl.label .. ": " .. (value and "ON" or "OFF")
            btn.TextColor3 = value and ui.theme.GOOD or ui.theme.TEXT2
        end)
        return
    end
    if ctrl.kind == "dropdown" then
        local index = 1
        local btn = ui:_makeButton(parent, ctrl.label, function()
            local items = ctrl.items or {}
            if #items == 0 then return end
            index = index + 1
            if index > #items then index = 1 end
            callSetter(ctrl.binding, items[index])
            ui:Refresh()
        end, {size = UDim2.new(1, 0, 0, 34)})
        ui:AddRefresher(function()
            local value = callGetter(ctrl.binding)
            for i, item in ipairs(ctrl.items or {}) do
                if item == value then
                    index = i
                    break
                end
            end
            btn.Text = ctrl.label .. ": " .. asText(value or (ctrl.items and ctrl.items[index]) or "--")
        end)
        return
    end
    if ctrl.kind == "slider" then
        local row = ui:_makePanel(parent, {size = UDim2.new(1, 0, 0, 46), transparency = 0.24, radius = 8, z = 36})
        local label = ui:_makeText(row, {text = ctrl.label, size = 12, pos = UDim2.fromOffset(12, 2), sizeUDim = UDim2.new(1, -24, 0, 20), color = ui.theme.TEXT2, z = 37})
        local bar = new("Frame", {BackgroundColor3 = ui.theme.BORDER, BackgroundTransparency = 0.40, BorderSizePixel = 0, Position = UDim2.fromOffset(12, 29), Size = UDim2.new(1, -24, 0, 5), ZIndex = 37}, row)
        Style.corner(bar, 4)
        local fill = new("Frame", {BackgroundColor3 = ui.theme.ACCENT, BorderSizePixel = 0, Size = UDim2.fromScale(0, 1), ZIndex = 38}, bar)
        Style.corner(fill, 4)
        local dragging = false
        local function setFromX(x)
            local rel = clamp((x - bar.AbsolutePosition.X) / math.max(1, bar.AbsoluteSize.X), 0, 1)
            local value = ctrl.min + ((ctrl.max - ctrl.min) * rel)
            if ctrl.step then value = math.floor((value / ctrl.step) + 0.5) * ctrl.step end
            callSetter(ctrl.binding, value)
            ui:Refresh()
        end
        ui.cleaner:Connect(row.InputBegan, function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; setFromX(input.Position.X) end
        end)
        ui.cleaner:Connect(UserInputService.InputEnded, function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
        end)
        ui.cleaner:Connect(UserInputService.InputChanged, function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then setFromX(input.Position.X) end
        end)
        ui:AddRefresher(function()
            local value = tonumber(callGetter(ctrl.binding)) or ctrl.min
            local rel = clamp((value - ctrl.min) / math.max(0.001, ctrl.max - ctrl.min), 0, 1)
            fill.Size = UDim2.fromScale(rel, 1)
            label.Text = ctrl.label .. ": " .. tostring(math.floor(value * 100 + 0.5) / 100)
        end)
        return
    end
    if ctrl.kind == "textbox" then
        local box = new("TextBox", {BackgroundColor3 = ui.theme.CARD2, BackgroundTransparency = scaleTransparency(0.18), BorderSizePixel = 0, ClearTextOnFocus = false, Text = "", PlaceholderText = ctrl.label, TextColor3 = ui.theme.TEXT, PlaceholderColor3 = ui.theme.DIM, TextSize = 12, Font = ui.theme.FONT_BODY, Size = UDim2.new(1, 0, 0, 34), ZIndex = 36}, parent)
        Style.corner(box, 8)
        Style.stroke(box, ui.theme.BORDER, 0.55, 1)
        ui.cleaner:Connect(box.FocusLost, function()
            callSetter(ctrl.binding, box.Text)
            ui:Refresh()
        end)
        ui:AddRefresher(function()
            local value = callGetter(ctrl.binding)
            if box.Text ~= asText(value) then box.Text = asText(value) end
        end)
        return
    end
    if ctrl.kind == "keybind" then
        local capture = false
        local btn = ui:_makeButton(parent, ctrl.label, function()
            capture = true
            btn.Text = ctrl.label .. ": press key"
        end, {size = UDim2.new(1, 0, 0, 34)})
        ui.cleaner:Connect(UserInputService.InputBegan, function(input, processed)
            if processed then return end
            if not capture then return end
            if input.UserInputType == Enum.UserInputType.Keyboard then
                capture = false
                callSetter(ctrl.binding, input.KeyCode)
                ui:Refresh()
            end
        end)
        ui:AddRefresher(function()
            local value = callGetter(ctrl.binding)
            btn.Text = ctrl.label .. ": " .. (value and value.Name or "None")
        end)
    end
end

