    local label = new("TextLabel", {
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Text = opt.text or "",
        TextColor3 = opt.color or self.theme.TEXT,
        TextTransparency = opt.transparency or 0,
        TextSize = opt.size or 12,
        Font = opt.font or self.theme.FONT_BODY,
        TextXAlignment = opt.x or Enum.TextXAlignment.Left,
        TextYAlignment = opt.y or Enum.TextYAlignment.Center,
        Size = opt.sizeUDim or UDim2.new(1, 0, 0, opt.height or 22),
