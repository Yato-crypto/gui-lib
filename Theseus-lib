end

function ViewportSpec:_strip(model)
    for _, item in ipairs(model:GetDescendants()) do
        if item:IsA("Script") or item:IsA("LocalScript") then
            item:Destroy()
        elseif item:IsA("BasePart") then
            item.Anchored = true
            item.CanCollide = false
        end
    end
end

function ViewportSpec:_frameCamera()
    if not self.clone or not self.camera then return end
    local cf, size = self.clone:GetBoundingBox()
    local mag = math.max(size.X, size.Y, size.Z, 4)
    local center = cf.Position
    self.camera.CFrame = CFrame.new(center + Vector3.new(0, mag * 0.20, mag * 1.85), center + Vector3.new(0, mag * 0.05, 0))
end

function ViewportSpec:_rebuildClone()
    if self.clone then self.clone:Destroy(); self.clone = nil end
    if not self.character or not self.world then return end
    local old = self.character.Archivable
    pcall(function() self.character.Archivable = true end)
    local ok, clone = pcall(function() return self.character:Clone() end)
    pcall(function() self.character.Archivable = old end)
    if not ok or not clone then return end
    self:_strip(clone)
    clone.Parent = self.world
    self.clone = clone
    self:_frameCamera()
end

function ViewportSpec:_syncMotors()
    if not self.character or not self.clone then return end
    local sourceMotors = {}
    for _, obj in ipairs(self.character:GetDescendants()) do
        if obj:IsA("Motor6D") then sourceMotors[obj.Name] = obj end
    end
    for _, obj in ipairs(self.clone:GetDescendants()) do
        if obj:IsA("Motor6D") then
            local src = sourceMotors[obj.Name]
            if src then obj.Transform = src.Transform end
        end
    end
end

function ViewportSpec:SetCharacter(character)
    self.character = character
    if self.world then self:_rebuildClone() end
    return self
end

function ViewportSpec:SetLiveSync(enabled)
    self.live = enabled == true
    if self.conn then self.conn:Disconnect(); self.conn = nil end
    if self.live and self.tab.ui and self.viewport then
        self.conn = RunService.RenderStepped:Connect(function()
            self:_syncMotors()
        end)
        self.tab.ui.cleaner:Give(self.conn)
    end
    return self
end

function ViewportSpec:Destroy()
    if self.conn then self.conn:Disconnect(); self.conn = nil end
    if self.clone then self.clone:Destroy(); self.clone = nil end
end

