function CombatDomain:SetVisibility(on)
    if CombatDomain._defaultWindow then
        CombatDomain._defaultWindow:SetVisibility(on)
    end
end

function CombatDomain:IsVisible()
    return CombatDomain._defaultWindow and CombatDomain._defaultWindow:IsVisible() or false
end

function CombatDomain:Destroy()
    for _, window in ipairs(CombatDomain.Windows) do
        pcall(function() window:Destroy() end)
    end
    table.clear(CombatDomain.Windows)
    CombatDomain._defaultWindow = nil
end

