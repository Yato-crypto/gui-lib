local function bindHover(window, frame, baseAlpha, accentLine)
    if not frame or frame:GetAttribute("MotionBound") then return end
    local config = window.Config
    frame:SetAttribute("MotionBound", true)
    local strokeObj = frame:FindFirstChildOfClass("UIStroke")
    local normalAlpha = baseAlpha ~= nil and baseAlpha or frame.BackgroundTransparency
    local normalStroke = strokeObj and strokeObj.Transparency or 0.58
    local normalPos = frame.Position
    frame:SetAttribute("MotionBasePos", normalPos)
    window:_track(frame.MouseEnter:Connect(function()
        if config.REDUCED_MOTION then return end
        local basePos = frame:GetAttribute("MotionBasePos") or normalPos
        createTween(config, frame, {
            BackgroundTransparency = math.max(0, normalAlpha - 0.06),
            Position = UDim2.new(basePos.X.Scale, basePos.X.Offset, basePos.Y.Scale, basePos.Y.Offset - (config.PANEL_HOVER_LIFT_PX or 2)),
        }, 0.14, Enum.EasingStyle.Quart, Enum.EasingDirection.Out):Play()
        if strokeObj then
            createTween(config, strokeObj, {Transparency = math.max(0.18, normalStroke - 0.22), Color = config.ACCENT}, 0.14, Enum.EasingStyle.Quart, Enum.EasingDirection.Out):Play()
        end
        if accentLine then
            createTween(config, accentLine, {
                BackgroundTransparency = config.PANEL_HOVER_LINE_ALPHA or 0.28,
                Size = UDim2.new(0.56, 0, 0, 2),
            }, 0.14, Enum.EasingStyle.Quart, Enum.EasingDirection.Out):Play()
        end
    end))
    window:_track(frame.MouseLeave:Connect(function()
        local basePos = frame:GetAttribute("MotionBasePos") or normalPos
        createTween(config, frame, {
            BackgroundTransparency = normalAlpha,
            Position = basePos,
        }, 0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out):Play()
        if strokeObj then
            createTween(config, strokeObj, {Transparency = normalStroke, Color = config.BORDER}, 0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out):Play()
        end
        if accentLine then
            createTween(config, accentLine, {
                BackgroundTransparency = config.PANEL_IDLE_LINE_ALPHA or 0.62,
                Size = UDim2.new(0.36, 0, 0, 2),
            }, 0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out):Play()
        end
    end))
end

local function animateCardSet(window, root)
    local config = window.Config
    if not root or config.REDUCED_MOTION then return end
    local cards = {}
    for _, desc in ipairs(root:GetDescendants()) do
        if desc:IsA("Frame") and desc:GetAttribute("AnimCard") then
            table.insert(cards, desc)
        end
    end
    table.sort(cards, function(a, b)
        return (a.AbsolutePosition.Y or 0) < (b.AbsolutePosition.Y or 0)
    end)
    for i, card in ipairs(cards) do
        local basePos = card:GetAttribute("AnimBasePos")
        if typeofSafe(basePos) ~= "UDim2" then
            basePos = card.Position
            card:SetAttribute("AnimBasePos", basePos)
        end
        local baseAlpha = card:GetAttribute("AnimBaseAlpha")
        if type(baseAlpha) ~= "number" then
            baseAlpha = card.BackgroundTransparency
            card:SetAttribute("AnimBaseAlpha", baseAlpha)
        end
        card.Position = UDim2.new(basePos.X.Scale, basePos.X.Offset, basePos.Y.Scale, basePos.Y.Offset + (config.PANEL_ENTER_OFFSET_Y or 10))
        card.BackgroundTransparency = math.min(1, baseAlpha + 0.12)
        local st = card:FindFirstChildOfClass("UIStroke")
        local stAlpha = st and st.Transparency or nil
        if st then st.Transparency = math.min(1, stAlpha + 0.18) end
        task.delay((i - 1) * 0.018, function()
            if not card or not card.Parent then return end
            createTween(config, card, {
                Position = basePos,
                BackgroundTransparency = baseAlpha,
            }, config.PANEL_ENTER_TIME or 0.34, Enum.EasingStyle.Quint, Enum.EasingDirection.Out):Play()
            card:SetAttribute("MotionBasePos", basePos)
            if st and st.Parent then
                createTween(config, st, {Transparency = stAlpha}, (config.PANEL_ENTER_TIME or 0.28) * 0.92, Enum.EasingStyle.Quint, Enum.EasingDirection.Out):Play()
            end
        end)
    end
end

