function Window:_bindDomainScale()
    local config = self.Config
    local function updateScale()
        if not self.Root then return end
        local s = self.Root.AbsoluteSize
        if s.X <= 0 or s.Y <= 0 then return end
        local scale = math.min(1, math.min(s.X / 1180, s.Y / 720))
        self.ResponsiveScale = math.clamp(scale, 0.78, 1)
        if self.Visible and self.ContentScale then
            self.ContentScale.Scale = self.ResponsiveScale
        end
        local compact = s.X < 900
        if self.TabScroll then
            self.TabScroll.Size = compact and UDim2.new(1, -48, 0, 38) or UDim2.new(1, -364, 0, 38)
        end
        if self.TabDock then
            self.TabDock.Size = compact and UDim2.new(1, -44, 0, 42) or UDim2.new(1, -360, 0, 42)
        end
        if self.CommandHint then
            self.CommandHint.Visible = not compact
            self.CommandHint.Position = compact and UDim2.new(1, -24, 0, 42) or UDim2.new(1, -30, 0, 42)
        end
        task.defer(function()
            self:_scrollTabIntoView(self.ActiveTabKey, true)
            self:_moveTabIndicator(self.ActiveTabKey, true)
        end)
    end
    self:_track(self.Root:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateScale))
    task.defer(updateScale)
end

function Window:_bindHotkeys()
    local config = self.Config
    local keybind = resolveKey(self.Options.ToggleUIKeybind or self.Options.DomainKey, config.DOMAIN_KEY)
    local altKeybind = resolveKey(self.Options.ToggleUIAltKeybind, config.DOMAIN_KEY_ALT)
    local nextKey = resolveKey(self.Options.NextTabKey, config.TAB_NEXT_KEY)
    local prevKey = resolveKey(self.Options.PrevTabKey, config.TAB_PREV_KEY)
    self.ToggleKeybind = keybind
    self.ToggleAltKeybind = altKeybind
    self.NextTabKey = nextKey
    self.PrevTabKey = prevKey

    local function typingBlocked()
        return config.HOTKEY_BLOCK_WHILE_TYPING ~= false and isTextBoxFocused()
    end

    local useContextAction = self.Options.UseContextActionHotkey ~= false and config.HOTKEY_USE_CONTEXT_ACTION ~= false
    if useContextAction then
        local actionName = "CombatDomainToggle_" .. tostring(HttpService:GenerateGUID(false))
        self.ContextActionName = actionName
        local priority = tonumber(self.Options.HotkeyPriority or config.HOTKEY_CONTEXT_PRIORITY) or 999999
        local ok = pcall(function()
            ContextActionService:BindActionAtPriority(actionName, function(_, inputState, inputObject)
                if inputState ~= Enum.UserInputState.Begin then
                    return Enum.ContextActionResult.Sink
                end
                if self.Destroyed then
                    return Enum.ContextActionResult.Sink
                end
                if typingBlocked() then
                    return Enum.ContextActionResult.Pass
                end
                if inputObject and inputObject.UserInputType == Enum.UserInputType.Keyboard then
                    self:Toggle()
                    return Enum.ContextActionResult.Sink
                end
                return Enum.ContextActionResult.Pass
            end, false, priority, keybind, altKeybind)
        end)
        self.ContextHotkeyBound = ok
        if ok then
            self:_track(function()
                pcall(function()
                    ContextActionService:UnbindAction(actionName)
                end)
            end)
        end
    end

    self:_track(UserInputService.InputBegan:Connect(function(input, processed)
        if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
        if typingBlocked() then return end

        local code = input.KeyCode
        local isToggleKey = code == keybind or code == altKeybind
        local isNavKey = self.Visible and (code == nextKey or code == prevKey)
        local allowProcessedHotkey = config.GUI_IGNORE_PROCESSED_FOR_HOTKEYS ~= false

        if processed and config.GUI_IGNORE_PROCESSED and not (allowProcessedHotkey and (isToggleKey or isNavKey)) then
            return
        end

        if isToggleKey then
            if not self.ContextHotkeyBound then
                self:Toggle()
            end
        elseif code == nextKey and self.Visible then
            self:NextTab()
        elseif code == prevKey and self.Visible then
            self:PreviousTab()
        end
    end))
end
