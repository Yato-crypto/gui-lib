    tint.BackgroundTransparency = tonumber(options.TintTransparency) or config.DOMAIN_BG_TINT_TRANSPARENCY
    tint.BorderSizePixel = 0
    tint.ZIndex = 9
    tint.Parent = bg

    if options.ScanlineEnabled ~= false then
        local scan = Instance.new("Frame")
        scan.Name = "SitrepFrameScanline"
        scan.Position = UDim2.new(0, 0, -0.04, 0)
        scan.Size = UDim2.new(1, 0, 0, tonumber(options.ScanlineHeight) or 2)
        scan.BackgroundColor3 = config.ACCENT
        scan.BackgroundTransparency = tonumber(options.ScanlineTransparency) or config.DOMAIN_BG_SCANLINE_ALPHA
        scan.BorderSizePixel = 0
        scan.ZIndex = 10
        scan.Parent = bg
        addGradient(scan, config, NumberSequence.new({
            NumberSequenceKeypoint.new(0, 1),
            NumberSequenceKeypoint.new(0.5, 0.16),
            NumberSequenceKeypoint.new(1, 1),
        }))
        local startClock = os.clock()
        self.BackgroundMaid:Give(RunService.RenderStepped:Connect(function()
            if not scan or not scan.Parent then return end
            local period = tonumber(options.ScanlinePeriod) or 3.2
            local y = ((os.clock() - startClock) / period) % 1.08
            scan.Position = UDim2.new(0, 0, y - 0.04, 0)
        end))
    end

    self:_applyCinematicBackdrop(options)
    return bg
end

function Window:_mountProceduralBackdrop(parent, options)
    local config = self.Config
    local count = tonumber(options.Count or options.Streaks or config.DOMAIN_BG_PROCEDURAL_COUNT) or 78
    local particles = tonumber(options.Particles or config.DOMAIN_BG_PROCEDURAL_PARTICLES) or math.floor(count * 0.44)
    local speed = tonumber(options.Speed or config.DOMAIN_BG_PROCEDURAL_SPEED) or 1.15
    local intensity = tonumber(options.Intensity) or 0.28
    local alpha = tonumber(options.Alpha or options.Transparency or config.DOMAIN_BG_PROCEDURAL_ALPHA) or 0.74
    alpha = math.clamp(alpha - (intensity * 0.10), 0.50, 0.94)

    local streaks = {}
    local motes = {}
    local rng = Random.new(tonumber(options.Seed) or math.floor(os.clock() * 100000) % 1000000)

    local starfield = Instance.new("Frame")
    starfield.Name = "CyberStarfield"
    starfield.Size = UDim2.new(1, 0, 1, 0)
    starfield.BackgroundTransparency = 1
    starfield.BorderSizePixel = 0
    starfield.ZIndex = 0
    starfield.Parent = parent

    local rainLayer = Instance.new("Frame")
    rainLayer.Name = "CyberRainLayer"
    rainLayer.Size = UDim2.new(1, 0, 1, 0)
    rainLayer.BackgroundTransparency = 1
    rainLayer.BorderSizePixel = 0
    rainLayer.ZIndex = 0
    rainLayer.Parent = parent

    local sweep = nil
    if options.SweepEnabled ~= false and config.DOMAIN_BG_SWEEP_ENABLED ~= false then
        sweep = Instance.new("Frame")
        sweep.Name = "CyberSweepBand"
        sweep.Position = UDim2.new(0, 0, -0.15, 0)
        sweep.Size = UDim2.new(1, 0, 0, tonumber(options.SweepHeight) or 92)
        sweep.BackgroundColor3 = config.ACCENT
        sweep.BackgroundTransparency = tonumber(options.SweepTransparency) or 0.935
        sweep.BorderSizePixel = 0
        sweep.ZIndex = 0
        sweep.Parent = parent
        local g = addGradient(sweep, config, NumberSequence.new({
            NumberSequenceKeypoint.new(0, 1),
            NumberSequenceKeypoint.new(0.5, 0.72),
            NumberSequenceKeypoint.new(1, 1),
        }))
        g.Rotation = 90
    end

    for i = 1, particles do
        local mote = Instance.new("Frame")
        mote.Name = "CyberDust"
        local size = rng:NextInteger(1, 3)
        mote.Position = UDim2.new(rng:NextNumber(), 0, rng:NextNumber(), 0)
        mote.Size = UDim2.new(0, size, 0, size)
        mote.BackgroundColor3 = (i % 5 == 0) and config.ACCENT_ALT or ((i % 3 == 0) and config.ACCENT_SOFT or config.ACCENT)
        mote.BackgroundTransparency = math.clamp(alpha + rng:NextNumber(0.05, 0.18), 0.68, 0.96)
        mote.BorderSizePixel = 0
        mote.ZIndex = 0
        mote.Parent = starfield
        addCorner(mote, size)
        motes[i] = {
            Frame = mote,
            X = mote.Position.X.Scale,
            Y = mote.Position.Y.Scale,
            Drift = rng:NextNumber(-0.010, 0.018),
            Rise = rng:NextNumber(-0.006, 0.020),
            Pulse = rng:NextNumber(1.1, 2.9),
            Offset = rng:NextNumber(0, math.pi * 2),
            BaseAlpha = mote.BackgroundTransparency,
        }
    end

    for i = 1, count do
        local streak = Instance.new("Frame")
        streak.Name = "CyberRainStreak"
        local width = rng:NextInteger(1, 3)
        local height = rng:NextInteger(22, 112)
        local x = rng:NextNumber(-0.08, 1.06)
        local y = rng:NextNumber(-0.16, 1.04)
        streak.Position = UDim2.new(x, 0, y, 0)
        streak.Size = UDim2.new(0, width, 0, height)
        streak.BackgroundColor3 = (i % 7 == 0) and config.ACCENT_ALT or ((i % 4 == 0) and config.ACCENT_SOFT or config.ACCENT)
        streak.BackgroundTransparency = math.clamp(alpha + rng:NextNumber(-0.08, 0.12), 0.54, 0.94)
        streak.BorderSizePixel = 0
        streak.ZIndex = 0
        streak.Parent = rainLayer
        addCorner(streak, 2)
        local grad = Instance.new("UIGradient")
        grad.Rotation = tonumber(options.Angle) or 14
        grad.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 1),
            NumberSequenceKeypoint.new(0.20, 0.18),
            NumberSequenceKeypoint.new(0.84, 0.40),
            NumberSequenceKeypoint.new(1, 1),
        })
        grad.Parent = streak
        streaks[i] = {
            Frame = streak,
            X = x,
            Y = y,
            Speed = rng:NextNumber(0.020, 0.070) * speed,
            Drift = rng:NextNumber(-0.010, 0.018) * speed,
            Pulse = rng:NextNumber(1.4, 3.8),
            Offset = rng:NextNumber(0, math.pi * 2),
            BaseAlpha = streak.BackgroundTransparency,
        }
    end

    local elapsed = 0
    self.BackgroundMaid:Give(RunService.RenderStepped:Connect(function(dt)
        if not parent or not parent.Parent or parent.Visible == false then return end
        elapsed += dt

        for _, data in ipairs(streaks) do
            local frame = data.Frame
            if frame and frame.Parent then
                data.Y += data.Speed * dt * 60
                data.X += data.Drift * dt * 60
                if data.Y > 1.14 then
                    data.Y = -0.18
                    data.X = rng:NextNumber(-0.08, 1.06)
                end
                if data.X > 1.08 then data.X = -0.08 end
                if data.X < -0.10 then data.X = 1.08 end
                frame.Position = UDim2.new(data.X, 0, data.Y, 0)
                frame.BackgroundTransparency = math.clamp(data.BaseAlpha + math.sin((elapsed * data.Pulse) + data.Offset) * 0.055, 0.48, 0.96)
            end
        end

        for _, data in ipairs(motes) do
            local frame = data.Frame
            if frame and frame.Parent then
                data.X += data.Drift * dt * 60
                data.Y += data.Rise * dt * 60
                if data.Y > 1.05 then data.Y = -0.04 end
                if data.Y < -0.06 then data.Y = 1.04 end
                if data.X > 1.04 then data.X = -0.04 end
                if data.X < -0.05 then data.X = 1.04 end
                frame.Position = UDim2.new(data.X, 0, data.Y, 0)
                frame.BackgroundTransparency = math.clamp(data.BaseAlpha + math.sin((elapsed * data.Pulse) + data.Offset) * 0.075, 0.58, 0.98)
            end
        end

        if sweep and sweep.Parent then
            local y = ((elapsed * 0.040 * speed) % 1.26) - 0.18
            sweep.Position = UDim2.new(0, 0, y, 0)
            sweep.BackgroundTransparency = math.clamp((tonumber(options.SweepTransparency) or 0.935) + math.sin(elapsed * 1.7) * 0.018, 0.88, 0.98)
        end
    end))
    return parent
end

function Window:_mountFrameBackdrop(parent, options)
    local config = self.Config
    local base = Instance.new("Frame")
    base.Name = "SitrepFrameBase"
    base.Size = UDim2.new(1, 0, 1, 0)
    base.BackgroundColor3 = Color3.fromRGB(8, 14, 28)
    base.BorderSizePixel = 0
