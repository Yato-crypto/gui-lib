    mergeInto(preset, overrides or {})
    if instance then
        local bgToken = preset.BackgroundToken or "SURFACE_RAISED"
        local strokeToken = preset.StrokeToken or "BORDER"
        pcall(function() instance.BackgroundColor3 = self.Config[bgToken] or self.Config.SURFACE_RAISED end)
        pcall(function() instance.BackgroundTransparency = preset.BackgroundTransparency or instance.BackgroundTransparency end)
        local st = instance:FindFirstChildOfClass("UIStroke") or addStroke(instance, self.Config[strokeToken] or self.Config.BORDER, preset.StrokeTransparency or 0.5)
        st.Color = self.Config[strokeToken] or self.Config.BORDER
        st.Transparency = preset.StrokeTransparency or st.Transparency
    end
    return instance
end

