    local fallback = nil
    if options.ProceduralFallback ~= false then
        fallback = Instance.new("Frame")
        fallback.Name = "CyberRainProcedural"
        fallback.Size = UDim2.new(1, 0, 1, 0)
        fallback.BackgroundTransparency = 1
        fallback.BorderSizePixel = 0
        fallback.ZIndex = 0
        fallback.Parent = parent
        self:_mountProceduralBackdrop(fallback, {
            Count = tonumber(options.FallbackCount) or math.floor((config.DOMAIN_BG_PROCEDURAL_COUNT or 78) * 0.65),
            Particles = tonumber(options.FallbackParticles) or math.floor((config.DOMAIN_BG_PROCEDURAL_PARTICLES or 34) * 0.65),
            Speed = tonumber(options.FallbackSpeed) or (config.DOMAIN_BG_PROCEDURAL_SPEED or 1.15),
            Intensity = tonumber(options.FallbackIntensity) or 0.24,
            Alpha = tonumber(options.FallbackAlpha) or 0.78,
            SweepEnabled = options.SweepEnabled,
        })
    end

    local host = Instance.new("Frame")
    host.Name = "SitrepFramePlayerHost"
    host.Size = UDim2.new(1, 0, 1, 0)
    host.BackgroundTransparency = 1
    host.BorderSizePixel = 0
    host.ClipsDescendants = true
    host.ZIndex = 1
    host.Parent = parent

    local alive = true
    self.BackgroundMaid:Give(function()
        alive = false
    end)

    task.spawn(function()
        local dir = tostring(options.Directory or options.Dir or config.SITREP_BG_FRAMES_DIR or "ForestCompanion/sitrep_frames")
        local count = tonumber(options.Count or config.SITREP_BG_FRAMES_COUNT) or 240
        local ext = tostring(options.Extension or options.Ext or config.SITREP_BG_FRAMES_EXT or "jpg")
        local pad = tonumber(options.Pad or config.SITREP_BG_FRAMES_PAD) or 4
        local prefix = tostring(options.Prefix or config.SITREP_BG_FRAMES_PREFIX or "frame_")
        local frameAssets, frameIndices = {}, {}

        for i = 1, count do
            local fileName = string.format("%s%0" .. tostring(pad) .. "d.%s", prefix, i, ext)
            local asset = resolveLocalAsset(joinPath(dir, fileName))
            if not asset and pad ~= 3 then
                local fallbackName = string.format("%s%03d.%s", prefix, i, ext)
                asset = resolveLocalAsset(joinPath(dir, fallbackName))
            end
            if asset then
                frameAssets[i] = asset
                table.insert(frameIndices, i)
            end
        end

        if not alive or not host or not host.Parent then return end
        if #frameIndices == 0 then
            return
        end

        local residentLimit = math.clamp(tonumber(options.ResidentLimit or config.SITREP_RESIDENT_FRAME_LIMIT) or 96, 1, count)
        local picked = sampledIndices(frameIndices, residentLimit)
        local labels = {}
        local zBack = 1
        local zTop = 2

        for slot, index in ipairs(picked) do
            if not alive or not host or not host.Parent then return end
            local label = Instance.new("ImageLabel")
            label.Name = string.format("SitrepResident_%03d", slot)
            label.AnchorPoint = Vector2.new(0.5, 0.5)
            label.Position = UDim2.new(0.5, 0, 0.5, 0)
            label.Size = UDim2.new(1.12, 0, 1.12, 0)
            label.BackgroundTransparency = 1
            label.BorderSizePixel = 0
            label.Image = frameAssets[index]
            label.ImageTransparency = (slot == 1) and (tonumber(options.ImageTransparency) or 0) or 1
            label.ScaleType = options.ScaleType or Enum.ScaleType.Crop
            label.ZIndex = (slot == 1) and zTop or zBack
            label.Parent = host
            labels[slot] = label
            if slot % 12 == 0 then task.wait() end
        end

        if not alive or not host or not host.Parent or #labels == 0 then return end
        preloadInChunks(labels, tonumber(options.PreloadChunkSize) or 16)
        if not alive or not host or not host.Parent then return end

        local warmup = tonumber(options.WarmupSeconds or config.SITREP_RESIDENT_WARMUP_SEC) or 4
        if warmup > 0 then task.wait(warmup) end
        if not alive or not host or not host.Parent then return end

        if fallback and fallback.Parent then
            fallback.Visible = false
        end

        if config.REDUCED_MOTION or options.ReducedMotion == true or #labels == 1 then
            labels[1].ImageTransparency = tonumber(options.ImageTransparency) or 0
            labels[1].ZIndex = zTop
            return
        end

        local fps = tonumber(options.FPS or options.Fps or config.SITREP_BG_FRAMES_FPS) or 10
        local cap = tonumber(options.StreamMaxFPS or options.StreamMaxFps or config.SITREP_STREAM_MAX_FPS) or fps
        fps = math.clamp(math.min(fps, cap), 1, 30)
        local interval = 1 / fps
        local cursor = 1
        local nextAt = os.clock() + interval
        self.BackgroundMaid:Give(RunService.RenderStepped:Connect(function()
            if not alive or not host or not host.Parent then return end
            local now = os.clock()
            if now < nextAt then return end
            repeat
                nextAt += interval
            until nextAt > now

            local prev = labels[cursor]
            cursor = (cursor % #labels) + 1
            local current = labels[cursor]
            if prev and prev.Parent then
                prev.ZIndex = zBack
                prev.ImageTransparency = 1
            end
            if current and current.Parent then
                current.ZIndex = zTop
                current.ImageTransparency = tonumber(options.ImageTransparency) or 0
            end
        end))
    end)

    return host
end

