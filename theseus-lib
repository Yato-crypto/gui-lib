local function addGradient(inst, config, transparency)
    local grad = Instance.new("UIGradient")
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0.00, config.ACCENT_ALT or config.ACCENT),
        ColorSequenceKeypoint.new(0.52, config.ACCENT),
        ColorSequenceKeypoint.new(1.00, config.ACCENT_SOFT or config.ACCENT),
    })
    if transparency then
        grad.Transparency = transparency
    end
    grad.Parent = inst
    return grad
end

