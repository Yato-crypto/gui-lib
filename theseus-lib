    shadeGrad.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.08),
        NumberSequenceKeypoint.new(0.52, 0.36),
        NumberSequenceKeypoint.new(1, 0.04),
    })
    shadeGrad.Parent = shade

    local tint = Instance.new("Frame")
