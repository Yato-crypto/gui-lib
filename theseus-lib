function CombatDomain:CreateWindow(options)
    options = options or {}
    local window = setmetatable({}, Window)
    window.Options = options
    window.Config = newConfig(options.Theme or options.Config or {})
    window.Maid = Maid.new()
    window.Tabs = {}
    window.TabsByKey = {}
    window.TabOrder = {}
    window.TabButtons = {}
    window.TabFrames = {}
    window.ResponsiveScale = 1
    window.BackgroundMaid = Maid.new()
    window:_buildDomain()
    table.insert(CombatDomain.Windows, window)
    if not CombatDomain._defaultWindow then CombatDomain._defaultWindow = window end
    return window
end

