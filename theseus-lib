        holder.BackgroundTransparency = 0.02
        holder.BorderSizePixel = 0
        holder.Visible = false
        holder.ClipsDescendants = true
        holder.ZIndex = 50
        holder.Parent = frame
        addCorner(holder, 7)
        addStroke(holder, config.BORDER, 0.45)
        local list = addList(holder, Enum.FillDirection.Vertical, 2)
        addPadding(holder, 4, 4, 4, 4)
        el.Display = display
        el.DisplayText = displayText
        el.Caret = caret
        el.Holder = holder
        el.OptionLayout = list
        el.Options = choices
        el.Multi = multi
        local function renderOptions()
            for _, child in ipairs(holder:GetChildren()) do
                if child:IsA("TextButton") then child:Destroy() end
            end
            for _, option in ipairs(el.Options or {}) do
                local text = tostring(option)
                local btn = makeTextButton(holder, config, {
                    Size = UDim2.new(1, 0, 0, 24),
                    BackgroundColor3 = config.SURFACE_RAISED,
                    BackgroundTransparency = 0.20,
                    Text = text,
                    TextSize = 10,
                    TextColor3 = config.TEXT_SECONDARY,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 52,
                })
                addCorner(btn, 5)
                addPadding(btn, 8, 8, 0, 0)
                self.Window:_track(btn.MouseButton1Click:Connect(function()
                    local nextValue = {}
                    if el.Multi then
                        for _, v in ipairs(el.CurrentOption or {}) do table.insert(nextValue, tostring(v)) end
                        local found = table.find(nextValue, text)
                        if found then table.remove(nextValue, found) else table.insert(nextValue, text) end
                    else
                        nextValue = {text}
                        open = false
                        holder.Visible = false
                        frame.Size = UDim2.new(1, 0, 0, tonumber(options.Height) or 48)
                    end
                    el:Set(nextValue)
                end))
            end
            holder.Size = UDim2.new(0, 170, 0, math.min(160, (#(el.Options or {}) * 26) + 8))
        end
        el.RenderOptions = renderOptions
        renderOptions()
        self.Window:_track(display.MouseButton1Click:Connect(function()
            open = not open
            holder.Visible = open
            if open then
                frame.Size = UDim2.new(1, 0, 0, (tonumber(options.Height) or 48) + holder.Size.Y.Offset + 8)
            else
                frame.Size = UDim2.new(1, 0, 0, tonumber(options.Height) or 48)
            end
        end))
    end)
    element.CurrentOption = current
    if flag then CombatDomain.Flags[flag] = current end
    element.SetFn = function(selfElement, value, silent)
        local v = value
        if type(v) ~= "table" then v = {v} end
        local clean = {}
        for _, item in ipairs(v) do table.insert(clean, tostring(item)) end
        selfElement.CurrentOption = clean
        selfElement.CurrentValue = clean
        if flag then CombatDomain.Flags[flag] = clean end
        if selfElement.DisplayText then
            selfElement.DisplayText.Text = #clean > 0 and table.concat(clean, ", ") or "Select"
        end
        if not silent and options.Callback then
            task.spawn(function() pcall(options.Callback, clean) end)
        end
        return clean
    end
    function element:Refresh(newOptions, keepSelection)
        self.Options = newOptions or {}
        if self.RenderOptions then self.RenderOptions() end
        if not keepSelection then self:Set({}) end
    end
    element:Set(current, true)
    return element
end

function Tab:CreateKeybind(options)
    options = options or {}
    local config = self.Window.Config
    local current = resolveKey(options.CurrentKeybind or options.Keybind or Enum.KeyCode.Unknown, Enum.KeyCode.Unknown)
    local listening = false
    local element = self:_addElement("Keybind", tonumber(options.Height) or 46, function(frame, el)
        el.TitleLabel = makeLabel(frame, config, {
            Position = UDim2.new(0, 16, 0, 0),
            Size = UDim2.new(1, -120, 1, 0),
            Text = tostring(options.Name or "Keybind"),
            Font = config.FONT_HEADLINE,
            TextSize = 12,
            TextColor3 = config.TEXT_PRIMARY,
            ZIndex = 22,
        })
        local capture = makeTextButton(frame, config, {
            AnchorPoint = Vector2.new(1, 0.5),
            Position = UDim2.new(1, -16, 0.5, 0),
            Size = UDim2.new(0, 86, 0, 28),
            BackgroundColor3 = config.SURFACE,
            BackgroundTransparency = 0.10,
            Text = current.Name,
            TextSize = 10,
            TextColor3 = config.ACCENT,
            Font = config.FONT_MONO,
            ZIndex = 23,
        })
        addCorner(capture, 7)
        addStroke(capture, config.BORDER, 0.55)
        el.Capture = capture
        self.Window:_track(capture.MouseButton1Click:Connect(function()
            listening = true
            capture.Text = "..."
        end))
    end)
    element.CurrentKeybind = current
    self.Window:_track(UserInputService.InputBegan:Connect(function(input, processed)
        if processed and options.IgnoreProcessed ~= true then return end
        if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
        if listening then
            listening = false
            element:Set(input.KeyCode)
            return
        end
        if input.KeyCode == element.CurrentKeybind and options.Callback then
            task.spawn(function() pcall(options.Callback) end)
        end
    end))
    element.SetFn = function(selfElement, value, silent)
        local key = resolveKey(value, selfElement.CurrentKeybind or Enum.KeyCode.Unknown)
        selfElement.CurrentKeybind = key
        selfElement.CurrentValue = key
        if selfElement.Capture then selfElement.Capture.Text = key.Name end
        if not silent and options.ChangedCallback then
            task.spawn(function() pcall(options.ChangedCallback, key) end)
        end
        return key
    end
    return element
end

