function Window:_resolveBackgroundOptions(raw)
    local config = self.Config
    local options = {}
    if raw == false then
        options.Type = "None"
        return options
    end
    if type(raw) == "table" then
        mergeInto(options, raw)
    elseif raw == true or raw == nil then
        options.Mode = "frames"
    elseif type(raw) == "string" then
        options.Mode = raw
    end

    local enabled = options.Enabled
    if enabled == nil then enabled = options.enabled end
    if enabled == false then
        options.Type = "None"
        return options
    end

    local mode = options.Mode or options.mode or options.Type or options.type
    if mode == nil then
        mode = config.SITREP_BG_ENABLED and "frames" or "procedural"
    end
    mode = tostring(mode):lower()

    if mode == "none" or mode == "off" or mode == "false" then
        options.Type = "None"
    elseif mode == "frame" or mode == "frames" or mode == "resident" or mode == "residentbank" then
        options.Type = "Frames"
        options.Directory = options.Directory or options.Dir or options.Folder or options.folder or config.SITREP_BG_FRAMES_DIR
        options.Count = options.Count or options.count or config.SITREP_BG_FRAMES_COUNT
        options.Extension = options.Extension or options.Ext or options.extension or config.SITREP_BG_FRAMES_EXT
        options.Prefix = options.Prefix or options.prefix or config.SITREP_BG_FRAMES_PREFIX or "frame_"
        options.Pad = options.Pad or options.Digits or options.digits or config.SITREP_BG_FRAMES_PAD
        options.FPS = options.FPS or options.Fps or options.fps or config.SITREP_BG_FRAMES_FPS
        options.StreamMaxFPS = options.StreamMaxFPS or options.StreamMaxFps or options.streamMaxFps or config.SITREP_STREAM_MAX_FPS
        options.ResidentLimit = options.ResidentLimit or options.residentLimit or config.SITREP_RESIDENT_FRAME_LIMIT
        options.WarmupSeconds = options.WarmupSeconds or options.warmupSeconds or config.SITREP_RESIDENT_WARMUP_SEC
        options.ProceduralFallback = options.ProceduralFallback
        if options.ProceduralFallback == nil then options.ProceduralFallback = options.proceduralFallback end
        if options.ProceduralFallback == nil then options.ProceduralFallback = config.SITREP_BG_PROCEDURAL_FALLBACK end
    elseif mode == "image" or mode == "static" then
        options.Type = "Image"
    else
        options.Type = "ProceduralRain"
    end

    local dimValue = options.dim or options.Dim
    if options.ShadeTransparency == nil and dimValue ~= nil then
        local dim = math.clamp(tonumber(dimValue) or 0.32, 0, 1)
        options.ShadeTransparency = 1 - dim
    end
    if options.Scanline == false or options.scanline == false then
        options.ScanlineEnabled = false
    end
    return options
end

