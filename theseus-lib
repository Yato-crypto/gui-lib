        self:_tween(activeBg, {BackgroundTransparency = config.HUD_HOVER_ALPHA}, 0.12):Play()
        self:_tween(bottomGlow, {BackgroundTransparency = 0.55}, 0.12):Play()
    end))

    self:_track(b.MouseButton1Down:Connect(function()
        self:_tween(activeBg, {BackgroundTransparency = 0.18}, 0.06):Play()
        self:_tween(bottomGlow, {BackgroundTransparency = 0.18}, 0.06):Play()
    end))

    self:_track(b.MouseLeave:Connect(function()
        if self.ActiveTabKey == key then return end
        b.TextColor3 = config.TAB_INACTIVE
        local tabIcon = b:FindFirstChild("TabIcon")
        if tabIcon then tabIcon.ImageColor3 = config.TAB_INACTIVE end
        self:_tween(activeBg, {BackgroundTransparency = 1}, 0.16):Play()
        self:_tween(bottomGlow, {BackgroundTransparency = 1}, 0.16):Play()
    end))

    self:_track(b.MouseButton1Click:Connect(function()
        self:SelectTab(key)
    end))

    return b
end

function Window:_scrollTabIntoView(key, instant)
    if not key then return end
    local btn = self.TabButtons[key]
    if not btn or not self.TabScroll or btn.AbsoluteSize.X <= 0 then return end
    local function applyScroll()
        if not btn or not btn.Parent or btn.AbsoluteSize.X <= 0 then return end
        local canvasW = self.TabScroll.CanvasSize.X.Offset
        local viewW = self.TabScroll.AbsoluteSize.X
        if canvasW <= viewW or viewW <= 0 then
            self.TabScroll.CanvasPosition = Vector2.new(0, 0)
            return
        end
        local currentX = self.TabScroll.CanvasPosition.X
        local btnLeft = btn.AbsolutePosition.X - self.TabScroll.AbsolutePosition.X + currentX
        local targetX = btnLeft - math.max(0, (viewW - btn.AbsoluteSize.X) * 0.5)
        targetX = math.clamp(targetX, 0, math.max(0, canvasW - viewW))
        if instant then
            self.TabScroll.CanvasPosition = Vector2.new(targetX, 0)
        else
            self:_tween(self.TabScroll, {CanvasPosition = Vector2.new(targetX, 0)}, 0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.Out):Play()
        end
    end
    task.defer(applyScroll)
end

function Window:_moveTabIndicator(key, instant)
    if not key then return end
    local btn = self.TabButtons[key]
    if not btn or not btn.Parent or not self.TabIndicator then return end
    local function applyMove()
        if not btn or not btn.Parent or btn.AbsoluteSize.X <= 0 then return end
        local rootX = self.Root.AbsolutePosition.X
        local x = btn.AbsolutePosition.X - rootX + 6
        local w = math.max(36, btn.AbsoluteSize.X - 12)
        local propsCore = {Position = UDim2.new(0, x, 0, 55), Size = UDim2.new(0, w, 0, 2)}
        local propsGlow = {Position = UDim2.new(0, x - 8, 0, 53), Size = UDim2.new(0, w + 16, 0, 5)}
        if instant then
            applyProps(self.TabIndicator, propsCore)
            applyProps(self.TabIndicatorGlow, propsGlow)
        else
            self:_tween(self.TabIndicator, propsCore, 0.24, Enum.EasingStyle.Quint, Enum.EasingDirection.Out):Play()
            self:_tween(self.TabIndicatorGlow, propsGlow, 0.28, Enum.EasingStyle.Quint, Enum.EasingDirection.Out):Play()
        end
    end
    task.defer(applyMove)
end

function Window:_applyTabVisuals(key, active)
    local config = self.Config
    local btn = self.TabButtons[key]
    if not btn then return end
    local activeBg = btn:FindFirstChild("ActiveBg")
    local bottomGlow = btn:FindFirstChild("BottomGlow")
    local icon = btn:FindFirstChild("TabIcon")
    btn.TextColor3 = active and config.TEXT_HEADLINE or config.TAB_INACTIVE
    btn.TextStrokeTransparency = active and 0.22 or config.TEXT_STROKE_ALPHA
    if icon then icon.ImageColor3 = active and config.TEXT_HEADLINE or config.TAB_INACTIVE end
    if activeBg then
        self:_tween(activeBg, {BackgroundTransparency = active and 0.18 or 1}, active and 0.16 or 0.18):Play()
    end
    if bottomGlow then
        self:_tween(bottomGlow, {BackgroundTransparency = active and 0.05 or 1}, active and 0.16 or 0.18):Play()
    end
end

function Window:CreateTab(name, icon, key)
    name = tostring(name or "Tab")
    key = tostring(key or name:gsub("%s+", "_"):lower())
    if self.TabsByKey[key] then return self.TabsByKey[key] end
    local config = self.Config
    local order = #self.TabOrder + 1
    local iconId = normalizeIcon(icon)
    local button = self:_createTabButton(name, order, iconId, key)

    local frame = Instance.new("Frame")
    applyProps(frame, STYLE.TabFrame)
    frame.Name = key
    frame.BackgroundColor3 = config.SURFACE
    frame.BackgroundTransparency = config.DOMAIN_TAB_FRAME_TRANSPARENCY or 0.42
    frame.Visible = false
    frame.Parent = self.ContentArea
    addCorner(frame, config.CARD_RADIUS)
    addStroke(frame, config.BORDER, config.DOMAIN_TAB_FRAME_STROKE or 0.42)
    addCyberAccent(frame, config, 0.28, 0.68)
    frame:SetAttribute("AnimCard", true)
    frame:SetAttribute("AnimBaseAlpha", frame.BackgroundTransparency)
    frame:SetAttribute("MotionBasePos", frame.Position)

    local scroll = Instance.new("ScrollingFrame")
    scroll.Name = "TabScroll"
    scroll.Position = UDim2.new(0, 14, 0, 14)
    scroll.Size = UDim2.new(1, -28, 1, -28)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 2
    scroll.ScrollBarImageColor3 = config.ACCENT
    scroll.ScrollBarImageTransparency = 0.4
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.ZIndex = 12
    scroll.Parent = frame
    addPadding(scroll, 2, 10, 0, 0)

    local content = Instance.new("Frame")
    content.Name = "ElementList"
    content.Size = UDim2.new(1, -4, 0, 0)
    content.BackgroundTransparency = 1
    content.BorderSizePixel = 0
    content.ZIndex = 13
    content.Parent = scroll

    local layout = addList(content, Enum.FillDirection.Vertical, 8, Enum.HorizontalAlignment.Left)
    self:_track(layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        local h = layout.AbsoluteContentSize.Y + 18
        content.Size = UDim2.new(1, -4, 0, h)
        scroll.CanvasSize = UDim2.new(0, 0, 0, h)
    end))

    local tab = setmetatable({}, Tab)
    tab.Window = self
    tab.Name = name
    tab.Key = key
    tab.Icon = iconId
    tab.Button = button
    tab.Frame = frame
    tab.Scroll = scroll
    tab.Content = content
    tab.Layout = layout
    tab.Elements = {}
    tab.Maid = Maid.new()

    self.TabsByKey[key] = tab
    table.insert(self.Tabs, tab)
    table.insert(self.TabOrder, key)
    self.TabButtons[key] = button
    self.TabFrames[key] = frame

    if not self.ActiveTabKey then
        self:SelectTab(key, true)
    end
    return tab
end

Window.CreatePage = Window.CreateTab
Window.AddTab = Window.CreateTab

function Window:SelectTab(key, instant)
    if not key then return end
    local target = self.TabsByKey[key]
    if not target then return end
    local prev = self.ActiveTabKey
    if prev == key then return target end
    self.ActiveTabKey = key
    for _, tabKey in ipairs(self.TabOrder) do
        local active = tabKey == key
        local frame = self.TabFrames[tabKey]
        self:_applyTabVisuals(tabKey, active)
        if frame then
            if active then
                frame.Visible = true
                frame.Position = UDim2.new(self.Config.TAB_SLIDE, 0, 0, 0)
                frame.BackgroundTransparency = math.min(1, self.Config.DOMAIN_TAB_FRAME_TRANSPARENCY + 0.1)
                self:_tween(frame, {
                    Position = UDim2.new(0, 0, 0, 0),
                    BackgroundTransparency = self.Config.DOMAIN_TAB_FRAME_TRANSPARENCY,
                }, self.Config.TAB_TWEEN_TIME, Enum.EasingStyle.Quint, Enum.EasingDirection.Out):Play()
                task.defer(function() animateCardSet(self, frame) end)
            else
                frame.Visible = false
            end
        end
    end
    if self.CommandHint then
        self.CommandHint.Text = target.Name .. " - " .. tostring(self.Options.CommandHint or "Toggle close - Left/Right tabs")
    end
    self:_scrollTabIntoView(key, instant)
    self:_moveTabIndicator(key, instant)
    return target
end

function Window:GetTab(key)
    return self.TabsByKey[key]
end

function Window:NextTab()
    if #self.TabOrder == 0 then return end
    local idx = table.find(self.TabOrder, self.ActiveTabKey) or 1
    idx = idx + 1
    if idx > #self.TabOrder then idx = 1 end
    self:SelectTab(self.TabOrder[idx])
end

function Window:PreviousTab()
    if #self.TabOrder == 0 then return end
    local idx = table.find(self.TabOrder, self.ActiveTabKey) or 1
    idx = idx - 1
    if idx < 1 then idx = #self.TabOrder end
    self:SelectTab(self.TabOrder[idx])
end

function Window:SetVisibility(on)
    on = on and true or false
    if self.Visible == on then return end
    self.Visible = on
    if on then
        self.Gui.Enabled = true
        self.Root.BackgroundTransparency = 1
        self.ContentScale.Scale = 0.985
        self:_tween(self.Root, {BackgroundTransparency = 0}, self.Config.DOMAIN_OPEN_TIME, Enum.EasingStyle.Quint, Enum.EasingDirection.Out):Play()
        self:_tween(self.ContentScale, {Scale = self.ResponsiveScale or 1}, self.Config.DOMAIN_OPEN_TIME, Enum.EasingStyle.Quint, Enum.EasingDirection.Out):Play()
        task.defer(function() animateCardSet(self, self.TabFrames[self.ActiveTabKey]) end)
    else
        local t1 = self:_tween(self.Root, {BackgroundTransparency = 1}, self.Config.DOMAIN_OPEN_TIME * 0.7, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
        local t2 = self:_tween(self.ContentScale, {Scale = 0.985}, self.Config.DOMAIN_OPEN_TIME * 0.7, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
        t1:Play()
        t2:Play()
        task.delay(self.Config.DOMAIN_OPEN_TIME * 0.72, function()
            if self.Gui and not self.Visible then self.Gui.Enabled = false end
            if self.Root then self.Root.BackgroundTransparency = 0 end
        end)
    end
end

function Window:IsVisible()
    return self.Visible == true
end

function Window:Toggle()
    self:SetVisibility(not self.Visible)
end

function Window:Destroy()
    for _, tab in ipairs(self.Tabs) do
        if tab.Maid then tab.Maid:Clean() end
    end
    if self.BackgroundMaid then self.BackgroundMaid:Clean() end
    if self.BackgroundLayer then
        pcall(function() self.BackgroundLayer:Destroy() end)
        self.BackgroundLayer = nil
    end
    self.Maid:Clean()
    if self.Gui then
        pcall(function() self.Gui:Destroy() end)
    end
    self.Destroyed = true
end

