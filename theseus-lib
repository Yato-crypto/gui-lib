        barBg.Position = UDim2.new(0, 16, 0, 36)
        barBg.Size = UDim2.new(1, -32, 0, 5)
        barBg.BackgroundColor3 = config.BORDER
        barBg.BackgroundTransparency = 0.58
        barBg.BorderSizePixel = 0
        barBg.ZIndex = 22
        barBg.Parent = frame
        addCorner(barBg, 4)
        local fill = Instance.new("Frame")
        fill.Size = UDim2.new(tonumber(options.Percent) or 0, 0, 1, 0)
        fill.BackgroundColor3 = options.Color or config.ACCENT
        fill.BackgroundTransparency = 0.08
        fill.BorderSizePixel = 0
        fill.ZIndex = 23
        fill.Parent = barBg
        addCorner(fill, 4)
        addGradient(fill, config)
        el.Fill = fill
    end)
    element.CurrentValue = options.Value
    element.SetFn = function(selfElement, value)
        local display, pct
        if type(value) == "table" then
            display = value.Value or value.Text or selfElement.CurrentValue
            pct = value.Percent
        else
            display = value
        end
        selfElement.CurrentValue = display
        if selfElement.ValueLabel then selfElement.ValueLabel.Text = tostring(display) end
        if pct and selfElement.Fill then
            self.Window:_tween(selfElement.Fill, {Size = UDim2.new(math.clamp(tonumber(pct) or 0, 0, 1), 0, 1, 0)}, 0.12):Play()
        end
        return display
    end
    return element
end

