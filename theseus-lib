function Tab:CreateSlider(options)
    options = options or {}
    local config = self.Window.Config
    local flag = options.Flag
    local range = options.Range or {0, 100}
    local minValue = tonumber(range[1]) or 0
    local maxValue = tonumber(range[2]) or 100
    local increment = tonumber(options.Increment) or 1
    local suffix = tostring(options.Suffix or "")
    local current = tonumber(options.CurrentValue) or minValue
    local element = self:_addElement("Slider", tonumber(options.Height) or 60, function(frame, el)
        el.TitleLabel = makeLabel(frame, config, {
            Position = UDim2.new(0, 16, 0, 8),
            Size = UDim2.new(1, -110, 0, 18),
            Text = tostring(options.Name or "Slider"),
            Font = config.FONT_HEADLINE,
            TextSize = 12,
            TextColor3 = config.TEXT_PRIMARY,
            ZIndex = 22,
        })
        el.ValueLabel = makeLabel(frame, config, {
            AnchorPoint = Vector2.new(1, 0),
            Position = UDim2.new(1, -16, 0, 8),
            Size = UDim2.new(0, 90, 0, 18),
            Text = "--",
            Font = Enum.Font.Code,
            TextSize = 10,
            TextColor3 = config.ACCENT,
            TextXAlignment = Enum.TextXAlignment.Right,
            ZIndex = 22,
        })
        local track = Instance.new("Frame")
        track.Name = "SliderTrack"
        track.Position = UDim2.new(0, 16, 0, 38)
        track.Size = UDim2.new(1, -32, 0, 6)
        track.BackgroundColor3 = config.BORDER
        track.BackgroundTransparency = 0.54
        track.BorderSizePixel = 0
        track.ZIndex = 23
        track.Parent = frame
        addCorner(track, 4)
        local fill = Instance.new("Frame")
        fill.Name = "Fill"
        fill.Size = UDim2.new(0, 0, 1, 0)
        fill.BackgroundColor3 = config.ACCENT
        fill.BackgroundTransparency = 0.04
        fill.BorderSizePixel = 0
        fill.ZIndex = 24
        fill.Parent = track
        addCorner(fill, 4)
        addGradient(fill, config)
        el.Track = track
        el.Fill = fill
        local dragging = false
        local function valueFromX(x)
            local rel = math.clamp((x - track.AbsolutePosition.X) / math.max(track.AbsoluteSize.X, 1), 0, 1)
            local raw = minValue + (maxValue - minValue) * rel
            local stepped = math.floor((raw / increment) + 0.5) * increment
            return math.clamp(stepped, minValue, maxValue)
        end
        self.Window:_track(track.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                el:Set(valueFromX(input.Position.X))
            end
        end))
        self.Window:_track(UserInputService.InputChanged:Connect(function(input)
            if not dragging then return end
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                el:Set(valueFromX(input.Position.X))
            end
        end))
        self.Window:_track(UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end))
    end)
    element.CurrentValue = current
    if flag then CombatDomain.Flags[flag] = current end
    element.SetFn = function(selfElement, value, silent)
        local v = tonumber(value) or minValue
        v = math.clamp(math.floor((v / increment) + 0.5) * increment, minValue, maxValue)
        selfElement.CurrentValue = v
        if flag then CombatDomain.Flags[flag] = v end
        local pct = (v - minValue) / math.max(maxValue - minValue, 1)
        if selfElement.Fill then
            self.Window:_tween(selfElement.Fill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.08):Play()
        end
        if selfElement.ValueLabel then
            selfElement.ValueLabel.Text = tostring(v) .. (suffix ~= "" and (" " .. suffix) or "")
        end
        if not silent and options.Callback then
            task.spawn(function() pcall(options.Callback, v) end)
        end
        return v
    end
    element:Set(current, true)
    return element
end

