local function mergeInto(dst, src)
    if type(src) ~= "table" then return dst end
    for k, v in pairs(src) do
        if type(v) == "table" and type(dst[k]) == "table" and typeof(v) ~= "Color3" and typeof(v) ~= "UDim2" then
            mergeInto(dst[k], v)
        else
            dst[k] = v
        end
    end
    return dst
end

local function cloneTable(src)
    local out = {}
    for k, v in pairs(src or {}) do
        if type(v) == "table" and typeof(v) ~= "Color3" and typeof(v) ~= "UDim2" and typeof(v) ~= "EnumItem" then
            out[k] = cloneTable(v)
        else
            out[k] = v
        end
    end
    return out
end

