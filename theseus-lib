local function readBootstrapOverrides()
    local overrides = {}
    local env = nil
    pcall(function()
        if getgenv then env = getgenv() end
    end)
    env = env or _G
    local sources = {}
    if type(env) == "table" then
        table.insert(sources, env.COMBAT_COMMAND_CFG)
        table.insert(sources, env.FOREST_COMPANION_CFG)
        table.insert(sources, env.THESEUS_CFG)
    end
    for _, source in ipairs(sources) do
        if type(source) == "table" then
            for fromKey, toKey in pairs(BOOTSTRAP_KEY_MAP) do
                if source[fromKey] ~= nil then
                    overrides[toKey] = source[fromKey]
                end
            end
            if tostring(source.sitrepStreamMode or ""):lower() == "frames" then
                overrides.SITREP_BG_ENABLED = true
                overrides.SITREP_BG_VIDEO_ENABLED = false
            end
        end
    end
    return overrides
end

local function newConfig(overrides)
    local config = cloneTable(DEFAULT_CONFIG)
    mergeInto(config, readBootstrapOverrides())
    mergeInto(config, overrides or {})
    return config
end

local function applyProps(inst, props)
    for k, v in pairs(props or {}) do
        local ok = pcall(function()
            inst[k] = v
        end)
        if not ok then
            -- ignored intentionally; Roblox classes do not share every prop
        end
    end
    return inst
end

local function typeofSafe(v)
    local ok, t = pcall(function() return typeof(v) end)
    if ok then return t end
    return type(v)
end

local function resolveKey(value, fallback)
    fallback = fallback or Enum.KeyCode.RightShift
    if typeofSafe(value) == "EnumItem" then return value end
    if type(value) == "string" then
        local ok, key = pcall(function() return Enum.KeyCode[value] end)
        if ok and key then return key end
    end
    return fallback
end

local function keyName(key)
    if typeofSafe(key) == "EnumItem" then return key.Name end
    if key ~= nil then return tostring(key) end
    return "None"
end

local function isTextBoxFocused()
