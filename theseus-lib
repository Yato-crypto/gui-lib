end

local function normalizeIcon(icon)
    if not icon or icon == 0 or icon == "" then return nil end
    if type(icon) == "number" then return "rbxassetid://" .. tostring(icon) end
    local named = ICONS[tostring(icon):gsub("%s+", "")]
    if named then return named end
    return tostring(icon)
end

local function parentGui(screenGui, parent)
    local target = parent
    if not target then
        pcall(function()
            if gethui then target = gethui() end
        end)
    end
    if target then
        screenGui.Parent = target
    else
        screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
    end
    return screenGui
end

local function safeDisconnect(conn)
    pcall(function()
        if conn then conn:Disconnect() end
    end)
end

local function basename(path)
    path = tostring(path or "")
    return path:match("([^/\\]+)$") or path
end

local function joinPath(dir, file)
    dir = tostring(dir or "")
    file = tostring(file or "")
    if dir == "" then return file end
    if dir:sub(-1) == "/" or dir:sub(-1) == "\\" then
        return dir .. file
    end
    return dir .. "/" .. file
end

local function fileExists(path)
    local ok, result = pcall(function()
        return isfile and isfile(path)
    end)
    return ok and result == true
end

local function resolveLocalAsset(path)
    if not path or path == "" then return nil end
    local candidates = { tostring(path) }
    local base = basename(path)
    if base ~= path then
        table.insert(candidates, base)
    else
        table.insert(candidates, joinPath("ForestCompanion", base))
        table.insert(candidates, joinPath("CombatCommand", base))
    end
    for _, candidate in ipairs(candidates) do
        local canTry = true
        if isfile then
            canTry = fileExists(candidate)
        end
        if canTry then
            local ok, asset = pcall(function()
                if getcustomasset then
                    return getcustomasset(candidate)
                end
                return candidate
            end)
            if ok and asset and asset ~= "" then
                return asset, candidate
            end
        end
    end
    return nil
end

local function sampledIndices(indices, limit)
    local n = #indices
    limit = math.clamp(tonumber(limit) or n, 1, math.max(1, n))
    if n <= limit then
        local out = {}
        for i = 1, n do out[i] = indices[i] end
        return out
    end
    local out, used = {}, {}
    if limit == 1 then return { indices[1] } end
    for slot = 1, limit do
        local pos = math.floor(1 + ((slot - 1) * (n - 1) / (limit - 1)) + 0.5)
        pos = math.clamp(pos, 1, n)
        while used[pos] and pos < n do pos += 1 end
        while used[pos] and pos > 1 do pos -= 1 end
        if not used[pos] then
            used[pos] = true
            table.insert(out, indices[pos])
        end
    end
    table.sort(out)
    return out
end

local function preloadInChunks(instances, chunkSize)
    chunkSize = math.clamp(tonumber(chunkSize) or 16, 1, 64)
    for i = 1, #instances, chunkSize do
        local chunk = {}
        for j = i, math.min(#instances, i + chunkSize - 1) do
            table.insert(chunk, instances[j])
        end
        pcall(function()
            ContentProvider:PreloadAsync(chunk)
        end)
        task.wait()
    end
end


local Maid = {}
Maid.__index = Maid

function Maid.new()
    return setmetatable({Tasks = {}}, Maid)
end

function Maid:Give(taskObj)
    if taskObj then
        table.insert(self.Tasks, taskObj)
    end
    return taskObj
end

function Maid:Clean()
    for i = #self.Tasks, 1, -1 do
        local taskObj = self.Tasks[i]
        self.Tasks[i] = nil
        local t = typeofSafe(taskObj)
        if t == "RBXScriptConnection" then
            safeDisconnect(taskObj)
        elseif type(taskObj) == "function" then
            pcall(taskObj)
        elseif type(taskObj) == "table" and taskObj.Destroy then
            pcall(function() taskObj:Destroy() end)
        elseif typeofSafe(taskObj) == "Instance" then
            pcall(function() taskObj:Destroy() end)
        end
    end
end

